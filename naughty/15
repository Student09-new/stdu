DELIMITER //

CREATE PROCEDURE update_balance()
BEGIN

    UPDATE Account
    SET balance =
    CASE

        WHEN acc_type='Saving'
        THEN balance + (balance * 0.08)

        WHEN acc_type='Current'
        THEN balance + (balance * 0.05)

        ELSE balance

    END;

END //

DELIMITER ;

CALL update_balance();

