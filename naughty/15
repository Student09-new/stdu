CREATE DATABASE IF NOT EXISTS bank_account_db;

USE bank_account_db;

DROP PROCEDURE IF EXISTS update_balance;

DROP TABLE IF EXISTS Account;

CREATE TABLE Account(
    acc_no INT PRIMARY KEY,
    cust_name VARCHAR(50),
    balance INT,
    acc_type VARCHAR(20)
);

