DELIMITER //
CREATE PROCEDURE low_quantity_products()
BEGIN
    DECLARE done INT DEFAULT FALSE;
    DECLARE p_id INT;
    DECLARE p_name VARCHAR(50);
    DECLARE p_quantity INT;
    DECLARE prod_cursor CURSOR FOR
    SELECT prod_id, prod_name, quantity
    FROM Product
    WHERE quantity < 10;
    DECLARE CONTINUE HANDLER
    FOR NOT FOUND SET done = TRUE;
    OPEN prod_cursor;
    read_loop: LOOP
        FETCH prod_cursor
        INTO p_id, p_name, p_quantity;
        IF done THEN
            LEAVE read_loop;
        END IF;
        SELECT p_id AS Product_ID,
               p_name AS Product_Name,
               p_quantity AS Quantity;
    END LOOP;
    CLOSE prod_cursor;
END //
DELIMITER ;
CALL low_quantity_products();
