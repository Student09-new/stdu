DELIMITER //
CREATE PROCEDURE update_product_status()
BEGIN
    DECLARE done INT DEFAULT FALSE;
    DECLARE p_id INT;
    DECLARE p_quantity INT;
    DECLARE prod_cursor CURSOR FOR
    SELECT prod_id, quantity
    FROM Product;
    DECLARE CONTINUE HANDLER
    FOR NOT FOUND SET done = TRUE;
    OPEN prod_cursor;
    read_loop: LOOP
        FETCH prod_cursor
        INTO p_id, p_quantity;
        IF done THEN
            LEAVE read_loop;
        END IF;
        IF p_quantity > 10 THEN
            UPDATE Product
            SET status = 'In Stock'
            WHERE prod_id = p_id;
        ELSEIF p_quantity BETWEEN 1 AND 10 THEN
            UPDATE Product
            SET status = 'Limited Stock'
            WHERE prod_id = p_id;
        ELSE
            UPDATE Product
            SET status = 'Out of Stock'
            WHERE prod_id = p_id;
        END IF;
    END LOOP;
    CLOSE prod_cursor;
END //
DELIMITER ;
CALL update_product_status();
