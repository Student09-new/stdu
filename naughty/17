DROP PROCEDURE IF EXISTS update_product_status;
DROP TABLE IF EXISTS Product;
CREATE TABLE Product(
    prod_id INT PRIMARY KEY,
    prod_name VARCHAR(50),
    quantity INT,
    price INT,
    status VARCHAR(30)
);
