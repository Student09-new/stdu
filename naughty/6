DROP PROCEDURE IF EXISTS update_salary;

DELIMITER //

CREATE PROCEDURE update_salary()
BEGIN

    UPDATE Employee
    SET SAL =
    CASE
        WHEN SAL > 10000 THEN SAL + (SAL * 0.06)
        ELSE SAL + (SAL * 0.05)
    END;

END //

DELIMITER ;

CALL update_salary();

SELECT * FROM Employee;

DROP FUNCTION IF EXISTS salary_increment;

DELIMITER //

CREATE FUNCTION salary_increment(old_salary INT)
RETURNS INT
DETERMINISTIC
BEGIN

    DECLARE new_salary INT;

    IF old_salary > 10000 THEN
        SET new_salary = old_salary + (old_salary * 0.06);
    ELSE
        SET new_salary = old_salary + (old_salary * 0.05);
    END IF;

    RETURN new_salary;

END //

DELIMITER ;

SELECT EMPNO,
ENAME,
SAL AS old_salary,
salary_increment(SAL) AS new_salary
FROM Employee;
