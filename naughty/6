CREATE DATABASE IF NOT EXISTS employee_plsql_db;

USE employee_plsql_db;

DROP TABLE IF EXISTS Employee;

CREATE TABLE Employee(
    EMPNO INT PRIMARY KEY,
    ENAME VARCHAR(50),
    JOB VARCHAR(50),
    MGR INT,
    HIREDATE DATE,
    SAL INT,
    COMM INT,
    DEPTNO INT
);

