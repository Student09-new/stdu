SHOW TABLES;

SELECT * FROM Borrower;

SELECT * FROM Depositor;

SELECT * FROM Branch;

SELECT cust_name
FROM Borrower
WHERE cust_name IN(
    SELECT cust_name
    FROM Depositor
);

SELECT cust_name
FROM Borrower
WHERE cust_name NOT IN(
    SELECT cust_name
    FROM Depositor
);

SELECT branch_name
FROM Branch
WHERE assets < SOME(
    SELECT assets
    FROM Branch
    WHERE branch_city='Pune'
);

SELECT DISTINCT branch_name
FROM Branch;
