SELECT e.*
FROM Employee e, Assigned_To a, Project p
WHERE e.emp_id = a.emp_id
AND a.project_id = p.project_id
AND p.proj_name='Database Project';

SELECT emp_id
FROM Employee
WHERE emp_id NOT IN(
    SELECT emp_id
    FROM Assigned_To
);

SELECT p.project_id,
p.proj_name,
e.emp_id,
e.emp_name
FROM Project p, Employee e, Assigned_To a
WHERE p.project_id = a.project_id
AND e.emp_id = a.emp_id;

