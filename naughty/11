SELECT name, pay_rate
FROM Employee
WHERE emp_no < 123460
AND pay_rate > SOME(
    SELECT pay_rate
    FROM Employee
    WHERE emp_no >= 123460
);

SELECT *
FROM Employee
WHERE pay_rate = (
    SELECT MIN(pay_rate)
    FROM Employee
);

SELECT e.name, e.pay_rate
FROM Employee e, Duty_allocation d
WHERE e.emp_no = d.emp_no;
