CREATE DATABASE IF NOT EXISTS employee_duty_db;

USE employee_duty_db;

DROP TABLE IF EXISTS Duty_allocation;
DROP TABLE IF EXISTS Position_tbl;
DROP TABLE IF EXISTS Employee;

CREATE TABLE Employee(
    emp_no INT PRIMARY KEY,
    name VARCHAR(50),
    skill VARCHAR(50),
    pay_rate INT
);

CREATE TABLE Position_tbl(
    posting_no INT PRIMARY KEY,
    skill VARCHAR(50)
);

CREATE TABLE Duty_allocation(
    posting_no INT,
    emp_no INT,
    duty_date DATE,
    shift_type VARCHAR(20)
);

