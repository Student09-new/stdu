SELECT * FROM Employee;
SELECT * FROM Position_tbl;
SELECT * FROM Duty_allocation;
SELECT d.shift_type
FROM Employee e, Duty_allocation d
WHERE e.emp_no = d.emp_no
AND e.name='XYZ';
SELECT shift_type, COUNT(DISTINCT emp_no) AS total_employee
FROM Duty_allocation
GROUP BY shift_type;
SELECT e.name, e.skill, p.posting_no
FROM Employee e, Position_tbl p
WHERE e.skill = p.skill;
SELECT *
FROM Employee
WHERE pay_rate = (
    SELECT MIN(pay_rate)
    FROM Employee
);
SELECT e.name, e.pay_rate
FROM Employee e, Duty_allocation d
WHERE e.emp_no = d.emp_no;
SELECT COUNT(*) AS total_employees
FROM Employee;
SELECT SUM(pay_rate) AS total_payrate
FROM Employee;
SELECT name, AVG(pay_rate) AS average_payrate
FROM Employee
GROUP BY name;
SELECT MIN(pay_rate) AS minimum_payrate,
MAX(pay_rate) AS maximum_payrate
FROM Employee;
