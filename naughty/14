SELECT * FROM Project;

SELECT * FROM Employee;

SELECT * FROM Assigned_To;

SELECT e.*
FROM Employee e, Assigned_To a
WHERE e.emp_id = a.emp_id
AND a.project_id='C353';

SELECT DISTINCT e.emp_id, e.emp_name
FROM Employee e, Assigned_To a
WHERE e.emp_id = a.emp_id
AND a.project_id IN(
    SELECT project_id
    FROM Assigned_To
    WHERE emp_id = 107
);

SELECT emp_id
FROM Assigned_To
GROUP BY emp_id
HAVING COUNT(DISTINCT project_id)=(
    SELECT COUNT(*)
    FROM Project
);

SELECT emp_id
FROM Assigned_To
WHERE project_id IN(
    SELECT project_id
    FROM Assigned_To
    WHERE emp_id = 107
)
GROUP BY emp_id
HAVING COUNT(DISTINCT project_id)=(
    SELECT COUNT(DISTINCT project_id)
    FROM Assigned_To
    WHERE emp_id = 107
);

SELECT e.*
FROM Employee e, Assigned_To a, Project p
WHERE e.emp_id = a.emp_id
AND a.project_id = p.project_id
AND p.proj_name='Database Project';
