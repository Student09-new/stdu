SELECT employee_name
FROM Works
WHERE company_name='FBC';
SELECT e.employee_name, e.street, e.city
FROM Employee e, Works w
WHERE e.employee_name = w.employee_name
AND w.company_name='FBC'
AND w.salary > 10000;
SELECT employee_name
FROM Works
WHERE salary > ALL(
    SELECT salary
    FROM Works
    WHERE company_name='Small Bank Corporation'
);
SELECT company_name
FROM Works
GROUP BY company_name
ORDER BY SUM(salary)
LIMIT 1;
UPDATE Company
SET company_name='Infosys'
WHERE city='Pune';
SELECT company_name
FROM Company
WHERE company_name LIKE 'A%';
SELECT company_name
FROM Company
WHERE company_name LIKE '%a';
SELECT company_name
FROM Company
WHERE company_name LIKE '%ta%';
